# ─────────────────────────────────────────────
# Web App Server
# ─────────────────────────────────────────────
PORT=4000

# ─────────────────────────────────────────────
# FHIR API connection
# URL of the fhir-r4-api server the browser will call.
# In Codespaces: set this to the forwarded port-3000 URL, e.g.:
#   FHIR_API_BASE_URL=https://<codespace-name>-3000.preview.app.github.dev
# Locally:
#   FHIR_API_BASE_URL=http://localhost:3000
# ─────────────────────────────────────────────
FHIR_API_BASE_URL=http://localhost:3000

# API key that the browser will include in every FHIR request (x-api-key header)
FHIR_API_KEY=fhir-dev-api-key-change-me
